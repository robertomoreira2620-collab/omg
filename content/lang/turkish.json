        "dialogue_moogus13": "(heh.... benim aslında İMPOSTOR olduğumu bilmiyolar...)",
        "dialogue_moogus14": "mal dışından konuştun",
        "dialogue_sabotage0": "EVET!!! aptal!!!!!",
        "dialogue_sabotage1": "buna inandın!! ben aslında bir impostor'dum!!!! ",
        "dialogue_sabotage2": "s..sen....",
        "dialogue_sabotage3": "girlfriend .... sen.....",
        "dialogue_sabotage4": "bunu nasıl yapabilirsin??!!",
        "dialogue_sabotage5": "neden o ??!!",

        "dialogue_sabotage12": "evet",
        "dialogue_meltdown0": "ooooooooh ben bir hayaletiiiiim",
        "dialogue_meltdown1": "bendeee oooooooh ooohoh",
        "dialogue_meltdown2": "SİKTİR GİT KORKUTUCUSUN ",
        "dialogue_meltdown3": "evet... >:)",
        "dialogue_meltdown4": "OROSPU ÇOCUĞU ne yapıcaksın!!",
        "dialogue_meltdown5": "ö...özür dilerim.. sadece lütfen.. bana zarar verme..",
        "dialogue_meltdown6": "evde benim kocam ve çocuğum var....",
        "dialogue_meltdown7": "birşey diyimmi.. tamam ya. farklılıklarımızı bir kenara koyalım.",
        "dialogue_meltdown8": "beni ÖLDÜRDÜKTEN SONRA??? nasıl bir uyuşturucu kullanıyosun???",
        "dialogue_meltdown9": "kokain",
        "dialogue_meltdown10": "tamam mantıklı aslında",
        "dialogue_toogus0": "abi o kırmızı manyaktı, ordan canlı çıktığımıza mutluyum",
        "dialogue_toogus1": "canlı çıkmadıkki",
        "dialogue_toogus2": "Selam dostlar!",
        "dialogue_toogus3": "... sen kimsin",
        "dialogue_toogus4": "ben sadece görevlerini yapmaya çalışan masum bir crewmate'im!",
        "dialogue_toogus5": "hmmmm boyfriend ben buna güvenemedim...",
        "dialogue_toogus6": "hey hadi be! lütfen güven bana lütfen lütfen ",
        "dialogue_toogus7": "lütfen.",
        "dialogue_toogus8": "Nasıl konuştuğunun farkında mısın?sen AKLINI KAÇIRMIŞSIN.",
        "dialogue_toogus9": "tamam",
        "dialogue_toogus10": "tamam şimdi şarkı söylüyoruz :)",
        "dialogue_lights0": "WOW tamam be... ben impostor'dum.",
        "dialogue_lights1": "biliyoruz",
        "dialogue_lights2": "siz benim planlarımı boşa çıkarmayı çok seviyosunuz galiba..",
        "dialogue_lights3": "evet KOYMUŞUZ gerizekalı?",
        "dialogue_lights4": "tamam şimdi benden kurtulmanız için bir toplantı başlatmanız gerekiyor",
        "dialogue_lights5": "ama siz bir işe yaramak yerine BEEP BOOP şarkılarınızı söylemeyi tercih ettiniz",
        "dialogue_lights6": "yani benim için kolay bir win",
        "dialogue_lights7": "senden daha iyi şarkı söylüyorum",
        "dialogue_lights8": "HAYIR SÖYLEMİYOSUN BAŞLAT ŞUNU",
        "dialogue_mando0": "oha selam dostlar!!",
        "dialogue_mando1": "şey merhaba..?",
        "dialogue_mando2": "selam??",
        "dialogue_mando3": "bugün Among Us oynamak çok keyifli!",
        "dialogue_mando4": "şeyy..tamam?",
        "dialogue_mando5": "hey neden öyle davranıyosun :(",
        "dialogue_mando6": "yani bugün karşılaştığımız herkes bir İMPOSTOR çıkıp bizi öldürdü....",
        "dialogue_mando7": "oh. ",
        "dialogue_mando8": "bu biraz ırkçı değil mi ",
        "dialogue_mando9": "her among us aynı değildir",
        "dialogue_mando10": "haklısın özür dilerim",
        "dialogue_mando11": "herneyse görevleriniz ne?",
        "dialogue_mando12": "uhhhhh Rareblin'in \"Mando\" şarkısını söyle yazıyor",
        "dialogue_mando13": "ve emihead!",
        "dialogue_mando14": "harbimi bendede aynı görev var",
        "dialogue_mando15": "tamam",
        "dialogue_dlow0": "Vay be! B-bu harbiden keyifliydi! ^_^",
        "dialogue_dlow1": "düzgün konuşurmusun",
        "dialogue_dlow2": "pardon",
        "dialogue_dlow3": "vay be bu eylenceliydi!",
        "dialogue_dlow4": "şimdi bizi öldürecekmisin",
        "dialogue_dlow5": "öldürmekmi?? ben asla öyle kotü bir suç işlemem",
